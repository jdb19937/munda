# Faceplica — TABULA MUNDA

APOTHECA ?= .
FACE     ?= make

CC     ?= cc
CFLAGS ?= -Wall -Wextra -pedantic -std=c99 -O2
CFLAGS += -I. -I$(APOTHECA)/ison -I$(APOTHECA)/crispus

LIBISON      = $(APOTHECA)/ison/libison.a
LIBCRISPUS   = $(APOTHECA)/crispus/libcrispus.a
LIBPHANTASMA = $(APOTHECA)/phantasma/libphantasma.a
NEXUS_PFR    = `cat $(APOTHECA)/phantasma/nexus_phantasma 2>/dev/null`

# capita omnia — non opus exactis dependentiis per obiectum
CAPITA = cellula.h cella.h tabula.h terminalis.h oraculum.h cogitatio.h \
         utilia.h fictio.h genera.h \
         cellae/animae/feles.h cellae/animae/dalekus.h \
         cellae/animae/ursus.h cellae/animae/corvus.h \
         cellae/fixum.h cellae/cibus.h cellae/animus.h cellae/deus.h \
         cellae/dei/zodus.h cellae/dei/oculus.h \
         oracula/nativus.h oracula/nativus_lexator.h oracula/provisor.h \
         retis/retis.h

# omnes obiecti communes → libmunda.a
LIB_OBJ = \
    tabula.o \
    cellae/fixa/vacuum.o cellae/fixa/saxum.o cellae/fixa/murus.o \
    cellae/cibi/rapum.o cellae/cibi/fungus.o \
    cellae/animae/feles.o cellae/animae/dalekus.o \
    cellae/animae/ursus.o cellae/animae/corvus.o \
    cellae/dei/zodus.o cellae/dei/oculus.o cellae/deus.o \
    cella_ops.o cellae/fixum.o cellae/cibus.o cellae/animus.o \
    cogitatio.o utilia.o fictio.o \
    oraculum.o \
    oracula/openai.o oracula/xai.o oracula/anthropic.o oracula/fictus.o \
    oracula/nativus_cursus.o oracula/nativus_lexator.o \
    oracula/nativus_exercitatio.o oracula/nativus_provisor.o \
    retis/retis.o retis/serializa.o retis/visus.o retis/cliens.o retis/crudus.o

# nexus communis (omnes binarii principale utuntur)
NEXUS = libmunda.a $(LIBPHANTASMA) $(LIBCRISPUS) $(LIBISON)

# --- omnia ---

omnia: curre lude fare proba valida daemonium coniunge specta \
       fac_certificatum nativus_exercita proba_nativus

# --- submoduli ---

para:
	git submodule update --init ison crispus phantasma
	$(FACE) -C $(APOTHECA)/ison
	$(FACE) -C $(APOTHECA)/crispus
	$(FACE) -C $(APOTHECA)/phantasma

expara:
	git submodule deinit -f ison crispus phantasma

$(LIBISON):
	$(FACE) -C $(APOTHECA)/ison

$(LIBCRISPUS):
	$(FACE) -C $(APOTHECA)/crispus

$(LIBPHANTASMA):
	$(FACE) -C $(APOTHECA)/phantasma

# --- compilatio ---

%.o: %.c $(CAPITA)
	$(CC) $(CFLAGS) -c $< -o $@

oracula/%.o: oracula/%.c $(CAPITA)
	$(CC) $(CFLAGS) -c $< -o $@

retis/%.o: retis/%.c $(CAPITA)
	$(CC) $(CFLAGS) -c $< -o $@

# --- libmunda.a ---

libmunda.a: $(LIB_OBJ) $(LIBPHANTASMA) $(LIBCRISPUS) $(LIBISON)
	ar rcs $@ $(LIB_OBJ)

# --- binarii principales ---

curre: curre.o libmunda.a
	$(CC) $(CFLAGS) -o $@ curre.o $(NEXUS) $(NEXUS_PFR) -lm

lude: lude.o terminalis.o libmunda.a
	$(CC) $(CFLAGS) -o $@ lude.o terminalis.o $(NEXUS) $(NEXUS_PFR) -lm

fare: fare.o libmunda.a
	$(CC) $(CFLAGS) -o $@ fare.o $(NEXUS) $(NEXUS_PFR) -lm

daemonium: daemonium.o libmunda.a
	$(CC) $(CFLAGS) -o $@ daemonium.o $(NEXUS) $(NEXUS_PFR) -lm

coniunge: coniunge.o libmunda.a
	$(CC) $(CFLAGS) -o $@ coniunge.o $(NEXUS) $(NEXUS_PFR) -lm

specta: specta.o libmunda.a
	$(CC) $(CFLAGS) -o $@ specta.o $(NEXUS) $(NEXUS_PFR) -lm

fac_certificatum: fac_certificatum.o libmunda.a
	$(CC) $(CFLAGS) -o $@ fac_certificatum.o $(NEXUS) $(NEXUS_PFR) -lm

nativus_exercita: oracula/nativus_exercita.o libmunda.a
	$(CC) $(CFLAGS) -o $@ oracula/nativus_exercita.o $(NEXUS) $(NEXUS_PFR) -lm

proba_nativus: oracula/proba_nativus.o libmunda.a
	$(CC) $(CFLAGS) -o $@ oracula/proba_nativus.o $(NEXUS) $(NEXUS_PFR) -lm

CRISPUS_PROBA_OBJ = $(APOTHECA)/crispus/proba.o

$(CRISPUS_PROBA_OBJ): $(APOTHECA)/crispus/proba.c $(APOTHECA)/crispus/proba.h
	$(CC) $(CFLAGS) -c $< -o $@

proba: proba.o $(CRISPUS_PROBA_OBJ) libmunda.a
	$(CC) $(CFLAGS) -o $@ proba.o $(CRISPUS_PROBA_OBJ) $(NEXUS) -lm

valida: valida.o $(LIBISON)
	$(CC) $(CFLAGS) -o $@ valida.o $(LIBISON)

# --- mundatio ---

purga:
	rm -f $(LIB_OBJ) libmunda.a
	rm -f curre.o lude.o terminalis.o fare.o daemonium.o
	rm -f coniunge.o specta.o fac_certificatum.o proba.o valida.o
	rm -f oracula/nativus_exercita.o oracula/proba_nativus.o
	@if [ "$(APOTHECA)" = "." ]; then rm -f crispus/proba.o; fi
	rm -f curre lude fare proba valida proba_nativus nativus_exercita
	rm -f daemonium coniunge specta fac_certificatum
	rm -f nativus_dieta_1526.bin nativus_dieta_1526.lex

linte:
	insinulint -c *.[ch] retis/*.[ch] oracula/*.[ch] cellae/*.[ch] cellae/*/*.[ch]

.PHONY: omnia para expara purga linte
