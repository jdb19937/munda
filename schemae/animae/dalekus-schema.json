{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "titulus": "dalekus — bot quod oraculum rogat",
  "type": "object",
  "properties": {
    "nomen": {
      "type": "string",
      "descriptio": "nomen proprium daleki, e.g. A001"
    },
    "pondus": {
      "type": "integer",
      "descriptio": "pondus daleki",
      "default": 5
    },
    "vires": {
      "type": "integer",
      "descriptio": "quantum ponderis pellere possit",
      "default": 15
    },
    "vitalitas": {
      "type": "integer",
      "descriptio": "quantum impetum sustinere possit",
      "default": 20
    },
    "energia": {
      "type": "integer",
      "descriptio": "energia daleki — exhausto quiescit",
      "default": 100
    },
    "mens": {
      "type": "string",
      "descriptio": "cogitationes initiales daleki",
      "default": "expergiscor"
    }
  },
  "required": [
    "nomen"
  ]
}
