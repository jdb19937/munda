{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "titulus": "corvus — avis callida et rapax",
  "type": "object",
  "properties": {
    "nomen": {
      "type": "string",
      "descriptio": "nomen proprium corvi, e.g. C001"
    },
    "pondus": {
      "type": "integer",
      "descriptio": "pondus corvi",
      "default": 2
    },
    "vires": {
      "type": "integer",
      "descriptio": "quantum ponderis pellere possit",
      "default": 2
    },
    "vitalitas": {
      "type": "integer",
      "descriptio": "quantum impetum sustinere possit",
      "default": 2
    },
    "audacia": {
      "type": "integer",
      "descriptio": "audacia corvi — quanto audacior, tanto minus fugit",
      "default": 3
    },
    "mens": {
      "type": "string",
      "descriptio": "cogitationes initiales corvi",
      "default": "esurio"
    }
  },
  "required": [
    "nomen"
  ]
}
